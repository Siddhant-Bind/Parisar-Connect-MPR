generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums
enum Role {
  ADMIN
  RESIDENT
  GUARD
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum NoticeType {
  INFO
  EVENT
  ALERT
}

enum NoticePriority {
  LOW
  MEDIUM
  HIGH
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum NoticeVisibility {
  PRIVATE
  PUBLIC
}

enum VisitorStatus {
  PENDING
  APPROVED
  ENTERED
  EXITED
}

// Models

// NEW: Society Model for Multi-Society Support
model Society {
  id        String   @id @default(uuid())
  name      String
  address   String?
  creatorId String   // Creator Admin (special permissions)
  isActive  Boolean  @default(true)
  deletedAt DateTime? // Soft delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  notices    Notice[]
  complaints Complaint[]
  payments   Payment[]
  visitors   Visitor[]
  notifications Notification[]

  @@index([creatorId])
  @@index([deletedAt])
  @@map("societies")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  role           Role     @default(RESIDENT)
  password       String? // Supabase handles auth, this is optional
  
  // Society relation
  societyId      String?
  society        Society?  @relation(fields: [societyId], references: [id])
  
  // Resident-specific fields
  wing           String?
  flatNumber     String?
  contact        String? // Phone number
  
  // Authentication & Security
  mustChangePassword Boolean @default(false) // Force password change on first login
  isApprovedAdmin    Boolean @default(false) // For admins: requires Creator approval
  refreshToken       String?
  
  // Soft delete
  deletedAt      DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  complaints     Complaint[]
  payments       Payment[]
  visitorLogs    Visitor[] @relation("EnteredBy")
  notifications  Notification[]

  @@index([societyId, role])
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      NoticeType     @default(INFO)
  priority  NoticePriority @default(LOW)
  
  // Event-specific fields
  visibility      NoticeVisibility @default(PRIVATE)
  eventLink       String?
  targetSocieties String[]
  
  // Society relation
  societyId String
  society   Society  @relation(fields: [societyId], references: [id])
  
  // Soft delete
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([societyId, createdAt])
  @@index([deletedAt])
  @@map("notices")
}

model Complaint {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(OPEN)
  
  history     Json?    // Array of status changes { status, remark, updatedAt, updatedBy }

  residentId  String
  resident    User     @relation(fields: [residentId], references: [id])
  
  // Society relation
  societyId   String
  society     Society  @relation(fields: [societyId], references: [id])
  
  // Soft delete
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([societyId, status])
  @@index([residentId])
  @@index([deletedAt])
  @@map("complaints")
}

model Payment {
  id         String   @id @default(uuid())
  type       String   // e.g., "maintenance", "event"
  amount     Float
  status     PaymentStatus @default(PENDING)
  dueDate    DateTime
  month      String?

  residentId String
  resident   User     @relation(fields: [residentId], references: [id])
  
  // Society relation
  societyId  String
  society    Society  @relation(fields: [societyId], references: [id])
  
  // Soft delete
  deletedAt  DateTime?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([societyId, status])
  @@index([residentId, status])
  @@index([deletedAt])
  @@map("payments")
}

model Visitor {
  id            String   @id @default(uuid())
  name          String
  purpose       String
  wing          String
  flatNumber    String
  contact       String? // Visitor phone number
  
  entryTime     DateTime @default(now())
  exitTime      DateTime?
  status        VisitorStatus @default(ENTERED)
  documentImage String? // URL or Base64 of scanned document
  visitorType   String?   @default("Guest") // Guest, Delivery, Staff
  vehicleNumber String?
  
  // Walk-in flag: true = guard added directly, false = resident pre-approved
  isWalkIn      Boolean  @default(true)

  enteredBy     String?
  creator       User?    @relation("EnteredBy", fields: [enteredBy], references: [id])
  
  // Society relation
  societyId     String
  society       Society  @relation(fields: [societyId], references: [id])
  
  // Soft delete
  deletedAt     DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([societyId, entryTime])
  @@index([societyId, status, deletedAt])
  @@index([societyId, status, entryTime])
  @@index([status])
  @@index([isWalkIn])
  @@index([deletedAt])
  @@map("visitors")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   // "NOTICE", "COMPLAINT", "PAYMENT", "VISITOR"
  isRead    Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  societyId String
  society   Society  @relation(fields: [societyId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([societyId])
  @@map("notifications")
}
